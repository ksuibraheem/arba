# ════════════════════════════════════════════════════════════════
# ARBA Pricing Platform — Environment Configuration Template
# ════════════════════════════════════════════════════════════════
# 
# ⚠️ INSTRUCTIONS:
# 1. Copy this file and rename to .env
# 2. Fill in your actual credentials
# 3. NEVER commit .env to Git — it's in .gitignore
#
# 🛡️ SOVEREIGN v8.0 — All values are REQUIRED (no hardcoded fallbacks)
# ════════════════════════════════════════════════════════════════

# Firebase Configuration (from Firebase Console → Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Gemini API Key (for AI features — Phase 2)
GEMINI_API_KEY=

# Tap Payments (for subscription billing)
# Get from: https://dashboard.tap.company
VITE_TAP_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
VITE_TAP_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
VITE_TAP_MERCHANT_ID=000000

# Admin & Security
VITE_ADMIN_SECRET_KEY=change_this_to_a_strong_random_key
VITE_SUPER_ADMIN_EMAIL=admin@your-domain.com
