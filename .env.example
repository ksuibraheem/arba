# ═══════════════════════════════════════════════════════════════
# ARBA Pricing Platform — Environment Variables
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════

# ═══════ Firebase Configuration ═══════
VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ═══════ Encryption Key ═══════
VITE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ═══════ Admin & Security ═══════
VITE_ADMIN_SECRET_KEY=change_this_to_a_secure_key
VITE_SUPER_ADMIN_EMAIL=info@arba-sys.com

# ═══════ EmailJS (Support Notifications) ═══════
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ═══════ Tap Payments ═══════
VITE_TAP_SECRET_KEY=
VITE_TAP_PUBLIC_KEY=

# ═══════ Gemini AI ═══════
GEMINI_API_KEY=

# ═══════ App URL ═══════
VITE_APP_URL=http://localhost:3000
